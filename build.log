	tools/nitrogfx rawdata/battle_sprite/$(basename $file .png).NCGR rawdata/battle_sprite/$(basename $file .png).NCGR.lz; \
	tools/nitrogfx $file rawdata/battle_sprite/$(basename $file .png).NCLR -bitdepth 8; \
	mv rawdata/battle_sprite/$(basename $file .png).NCGR.lz build/a007/$(basename $file .png); \
	export FILENAME_TEMP=$(basename $file); \
	mv rawdata/battle_sprite/$(basename $file .png).NCLR build/a007/7_$(($(basename ${FILENAME_TEMP#*_} .png)+1)); \
done
. .venv/bin/activate; python3 tools/narcpy.py create build/narc/spriteoffsets.narc build/a180 -nf
for file in rawdata/battle_sprite/*.pal; do \
